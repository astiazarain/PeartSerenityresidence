<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Applied automatically to quotations generated from the website's
             care request / admission flow, so staff can spot them instantly
             in the standard Sales pipeline without a parallel data model. -->
        <record id="sale_order_template_care_quote" model="sale.order.template">
            <field name="name">Peart Serenity — Care Quote (Website)</field>
            <field name="note">Thank you for requesting a personalized care quote from Peart Serenity Residence.
Our care team has reviewed the submitted care assessment and prepared the service lines below.
Where Care Feels Like Home.</field>
        </record>

    </data>
</odoo>
