<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="peart_admission_view_list" model="ir.ui.view">
        <field name="name">peart.admission.list</field>
        <field name="model">peart.admission</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'declined'" decoration-success="state == 'admitted'">
                <field name="name"/>
                <field name="care_type_requested"/>
                <field name="care_level"/>
                <field name="applicant_email"/>
                <field name="urgency"/>
                <field name="create_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="peart_admission_view_form" model="ir.ui.view">
        <field name="name">peart.admission.form</field>
        <field name="model">peart.admission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_assessed" type="object" string="Mark Assessed"
                            invisible="state != 'new'" class="btn-primary"/>
                    <button name="action_create_quotation" type="object" string="Create Quotation"
                            invisible="state not in ('new', 'assessed')" class="btn-primary"/>
                    <button name="action_mark_admitted" type="object" string="Mark Admitted"
                            invisible="state != 'quoted'" class="btn-primary"/>
                    <button name="action_mark_declined" type="object" string="Decline"
                            invisible="state in ('admitted', 'declined')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,assessed,quoted,admitted"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_quotation" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="not sale_order_id">
                            <field name="sale_order_count" widget="statinfo" string="Quotation"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <field name="care_level" widget="badge"/>
                    </div>
                    <group>
                        <group string="Applicant">
                            <field name="applicant_name"/>
                            <field name="applicant_email"/>
                            <field name="applicant_phone"/>
                            <field name="applicant_relationship"/>
                            <field name="applicant_partner_id"/>
                        </group>
                        <group string="Resident">
                            <field name="resident_name"/>
                            <field name="resident_dob"/>
                            <field name="resident_gender"/>
                            <field name="resident_address"/>
                            <field name="resident_partner_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Care Needs">
                            <field name="care_type_requested"/>
                            <field name="preferred_start_date"/>
                            <field name="urgency"/>
                            <field name="mobility_level"/>
                            <field name="requires_specialized_care"/>
                            <field name="specialized_care_details" invisible="not requires_specialized_care"/>
                            <field name="suggested_product_id"/>
                        </group>
                        <group string="Medical">
                            <field name="primary_diagnosis"/>
                            <field name="medications"/>
                            <field name="allergies"/>
                            <field name="dietary_restrictions"/>
                            <field name="physician_name"/>
                            <field name="physician_phone"/>
                        </group>
                    </group>
                    <group>
                        <group string="Emergency Contact">
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact_relationship"/>
                            <field name="emergency_contact_phone"/>
                            <field name="emergency_contact_email"/>
                        </group>
                        <group string="Family / Financial">
                            <field name="family_physician"/>
                            <field name="insurance_provider"/>
                            <field name="insurance_number"/>
                            <field name="preferred_payment_method"/>
                        </group>
                    </group>
                    <group string="Additional Notes">
                        <field name="additional_notes" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="peart_admission_action" model="ir.actions.act_window">
        <field name="name">Care Admissions</field>
        <field name="res_model">peart.admission</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_action">No care admission requests yet.</p>
            <p>Submissions from the website's Quote Request form will appear here automatically.</p>
        </field>
    </record>

    <menuitem id="peart_admission_menu_root"
              name="Care Admissions"
              sequence="15"/>
    <menuitem id="peart_admission_menu_requests"
              name="Admission Requests"
              parent="peart_admission_menu_root"
              action="peart_admission_action"
              sequence="1"/>

</odoo>
